{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.output/public",
  "installCommand": "cd frontend && npm install",
  "framework": "nuxtjs",
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ]
}
